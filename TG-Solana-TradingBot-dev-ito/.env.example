# PostgreSQL Configuration
DATABASE_URL="postgresql://growtrade_user:CHANGE_THIS_STRONG_PASSWORD@localhost:5432/growtrade_db?schema=public"

# Telegram Configuration
TELEGRAM_BOT_API_TOKEN=""
ALERT_BOT_API_TOKEN=""

# Redis Configuration
REDIS_URI="redis://localhost:6379"

# Solana RPC Configuration
MAINNET_RPC="https://api.mainnet-beta.solana.com"
RPC_WEBSOCKET_ENDPOINT="wss://api.mainnet-beta.solana.com"
PRIVATE_RPC_ENDPOINT="https://api.mainnet-beta.solana.com"

# BirdEye API
BIRD_EVEY_API=""

# Jito Configuration
JITO_UUID=""
JITO_TIP_LAMPORTS="1500000"

# Additional APIs
GROWSOL_API_ENDPOINT="http://127.0.0.1:5001"
PNL_IMG_GENERATOR_API="http://127.0.0.1:3001"

# ============ PHASE 0: SECURITY SETTINGS ============

# Master encryption key for wallet private key encryption (AES-256-GCM)
# Generate with: openssl rand -base64 32
WALLET_MASTER_KEY="your-base64-encoded-32-byte-key"

# Fee Wallet Address (your revenue collection wallet)
FEE_WALLET_ADDRESS="your-solana-wallet-address"

# Fee Configuration (as percentages)
FEE_PERCENT_BUY="0.01"
FEE_PERCENT_SELL="0.01"
FEE_PERCENT_BURN="0.0075"

# Gas Fee Presets (in SOL)
GAS_FEE_DEFAULT="0.005"
GAS_FEE_NORMAL="0.001"
GAS_FEE_TURBO="0.025"
GAS_FEE_ULTRA="0.05"

# MEV Protection
MEV_PROTECT_ENABLED="true"
USE_JITO_BUNDLE="true"

# Security Settings
REQUIRE_SAP_FOR_WITHDRAW="true"
REQUIRE_SAP_FOR_KEY_EXPORT="true"
REQUIRE_SAP_FOR_WALLET_DELETE="true"
SAP_TIMEOUT_MINUTES="5"

# Trading Limits
MAX_SLIPPAGE_BPS="5000"
MAX_SINGLE_TRADE_SOL="100"
WARN_LARGE_TRADE_SOL="10"
